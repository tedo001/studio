{
  "entities": {
    "Report": {
      "title": "Report",
      "type": "object",
      "description": "Represents an environmental issue report including image, location, and status.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "aiCategory": { "type": "string" },
        "severity": { "type": "string", "enum": ["Low", "Medium", "High"] },
        "status": { "type": "string", "enum": ["Pending", "In Progress", "Resolved"] },
        "locationName": { "type": "string" },
        "location": {
          "type": "object",
          "properties": {
            "latitude": { "type": "number" },
            "longitude": { "type": "number" }
          }
        },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "imageUrl", "severity", "status", "timestamp"]
    },
    "User": {
      "title": "User",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "worker", "admin"] },
        "workerId": { "type": "string" },
        "workerPass": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "enrolledAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google", "password", "anonymous"]
  },
  "firestore": {
    "/reports/{reportId}": {
      "schema": { "$ref": "#/backend/entities/Report" },
      "description": "Global collection of environmental reports."
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "User profiles and workforce credentials."
    }
  }
}