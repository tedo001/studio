
{
  "entities": {
    "Report": {
      "title": "Environmental Report",
      "description": "A report of an environmental issue captured by a user.",
      "type": "object",
      "properties": {
        "imageUrl": {
          "type": "string",
          "description": "URL of the uploaded image of the issue."
        },
        "aiCategory": {
          "type": "string",
          "description": "Category suggested by AI analysis."
        },
        "severity": {
          "type": "string",
          "enum": ["Low", "Medium", "High"],
          "description": "The severity level of the issue."
        },
        "status": {
          "type": "string",
          "enum": ["Pending", "In Progress", "Resolved"],
          "description": "Current status of the report."
        },
        "timestamp": {
          "type": "object",
          "description": "Server timestamp of when the report was created."
        },
        "userId": {
          "type": "string",
          "description": "UID of the user who submitted the report."
        },
        "location": {
          "type": "object",
          "properties": {
            "latitude": { "type": "number" },
            "longitude": { "type": "number" }
          }
        },
        "locationName": {
          "type": "string",
          "description": "The human-readable address or area name retrieved via reverse geocoding."
        },
        "assignedTo": {
          "type": "string",
          "description": "UID of the worker assigned to this report."
        }
      },
      "required": ["imageUrl", "aiCategory", "severity", "status", "timestamp", "userId"]
    },
    "AppUser": {
      "title": "Application User",
      "description": "User profile with role management.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user", "worker"] },
        "workerId": { "type": "string", "description": "Unique ID assigned by admin for workers." },
        "workerPass": { "type": "string", "description": "Password assigned by admin for workers." }
      },
      "required": ["email", "role"]
    }
  },
  "auth": {
    "providers": ["anonymous", "password", "google.com"]
  },
  "firestore": {
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "Collection of environmental issue reports."
    },
    "/users/{userId}": {
      "schema": "AppUser",
      "description": "Collection of user profiles and roles."
    }
  }
}
