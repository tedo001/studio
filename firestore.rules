rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIRESTORE SECURITY RULES - PROTOTYPING MODE
     * 
     * Core Philosophy: 
     * This ruleset enforces a strict user-ownership model designed for privacy and security. 
     * Access is scoped to the individual user level to ensure that sensitive environmental 
     * reports are only accessible by the anonymous or registered users who created them.
     * 
     * Data Structure: 
     * All report data is hierarchically organized under user-specific paths: 
     * /users/{userId}/reports/{reportId}. This nesting facilitates clean authorization 
     * and high-performance list operations.
     * 
     * Key Security Decisions:
     * - Ownership via Path: Authorization is primarily derived from the document path. 
     *   If a user's UID matches the {userId} variable in the path, they are granted access.
     * - Denormalization: The 'userId' is stored both in the path and as a field within the 
     *   document. Rules enforce that these two values must match, providing redundant 
     *   validation and enabling flexible querying.
     * - Restricted Visibility: There is no public listing of reports. Users can only see 
     *   the specific reports they have submitted.
     * - Resource-First Updates: All update and delete operations verify the document's 
     *   existence and ownership before proceeding to prevent unauthorized modifications.
     */

    // --- Global Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the document exists and the user is the owner. Used for update/delete. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** @description Enforces that critical relational fields (like userId) do not change during updates. */
    function isUnchanged(fieldName) {
      return request.resource.data[fieldName] == resource.data[fieldName];
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the user profile document. Allows users to manage their own root entry.
     * @path /users/{userId}
     * @allow (create) User 'user_123' creates a document at /users/user_123.
     * @deny (create) User 'user_123' attempts to create a document at /users/user_999.
     * @principle Self-creation and ownership.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Users cannot be listed for privacy.
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for environmental reports. Access is strictly restricted to the report creator.
       * @path /users/{userId}/reports/{reportId}
       * @allow (list) User 'user_123' retrieves all documents under /users/user_123/reports.
       * @deny (get) User 'user_456' attempts to read a report at /users/user_123/reports/report_001.
       * @principle Path-based ownership and relational integrity validation.
       */
      match /reports/{reportId} {
        
        // Read: Users can only see their own reports.
        allow get, list: if isOwner(userId);

        // Create: User must be the owner of the path and set the internal userId correctly.
        allow create: if isOwner(userId) && request.resource.data.userId == userId;

        // Update: User must own the existing document and cannot change the userId field.
        allow update: if isExistingOwner(userId) && isUnchanged('userId');

        // Delete: User must own the existing document.
        allow delete: if isExistingOwner(userId);
      }
    }

    // Default deny for any paths not explicitly matched above.
    match /{path=**} {
      allow read, write: if false;
    }
  }
}