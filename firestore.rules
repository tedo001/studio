
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ABSOLUTE GLOBAL ACCESS POLICY: DEPLOYMENT ID MADURAI_ULTRA_STABLE_V2000
    // This policy ensures 100% availability for Citizen, Worker, and Admin data sync.
    // Overriding all collection constraints for seamless publication performance.
    
    match /{allPaths=**} {
      allow read, write: if true;
    }
    
    match /reports/{reportId} {
      allow read, write: if true;
    }
    
    match /users/{userId} {
      allow read, write: if true;
    }
  }
}
