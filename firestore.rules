
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ALLOW AUTHENTICATED ACCESS FOR PROTOTYPE ROBUSTNESS
    // This ensures Admin, User, and Worker can all see relevant reports
    // across the Anti-Gravity network.
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Future production hardening:
    // - Restrict user-specific data
    // - Enforce schema validation
    // - Role-based write access for status updates
  }
}
