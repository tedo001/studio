rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // GLOBAL ANTI-GRAVITY ACCESS POLICY: OPEN SECTOR
    // Optimized for the Madurai CleanUp Gov-Tech Ecosystem.
    // This allows seamless synchronization between Citizen (Anonymous), Admin, and Workforce modules.
    // Deployment ID: MADURAI_SYNC_PUBLISH_V110_STABLE_FINAL_OPEN
    
    // Explicitly allow list and get for the primary collections to bypass any deployment delays
    match /reports/{reportId} {
      allow read, write: if true;
    }
    
    match /users/{userId} {
      allow read, write: if true;
    }

    // Global fallback for total sector synchronization
    match /{allPaths=**} {
      allow read, write: if true;
    }
  }
}