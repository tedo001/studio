rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // GLOBAL ANTI-GRAVITY ACCESS POLICY
    // Optimized for the Madurai CleanUp Gov-Tech Ecosystem.
    // This allows seamless synchronization between Citizen, Admin, and Workforce modules.
    // Deployment ID: MADURAI_SYNC_PUBLISH_V108_STABLE_FINAL
    
    match /{allPaths=**} {
      allow read, write: if true;
    }
  }
}