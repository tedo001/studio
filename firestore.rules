rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // RE-DEPLOYMENT TRIGGER: 2024-05-21-04-ROBUST-ACCESS
    // We use recursive wildcards {allPaths=**} to ensure that both individual document access 
    // and collection-level queries (list operations) are permitted for authenticated users.
    
    match /users/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    match /reports/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Global fallback for any other collections created during prototyping
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}