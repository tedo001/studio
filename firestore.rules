rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // GLOBAL ANTI-GRAVITY ACCESS POLICY: PUBLIC SECTOR UNLOCKED
    // Authorized for the Madurai CleanUp Gov-Tech Ecosystem.
    // This policy ensures seamless synchronization for Anonymous Citizens, Staff, and Admins.
    // Deployment ID: MADURAI_SYNC_V120_STABLE_FINAL
    
    // Explicitly allow all read/write operations at the root to eliminate list/get permission blocks
    match /{allPaths=**} {
      allow read, write: if true;
    }
    
    // Redundant but specific matches for additional stability during propagation
    match /reports/{reportId} {
      allow get, list, create, update, delete: if true;
    }
    
    match /users/{userId} {
      allow get, list, create, update, delete: if true;
    }
  }
}