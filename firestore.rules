rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // RE-DEPLOYMENT TRIGGER: 2024-05-21-01
    // Explicitly allowing authenticated access to core collections
    // to ensure prototype robustness across Admin, User, and Worker modules.
    
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    
    match /reports/{reportId} {
      allow read, write: if request.auth != null;
    }

    // Global fallback to ensure no stray requests are blocked during prototyping
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}