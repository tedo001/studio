rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // RE-DEPLOYMENT TRIGGER: 2024-05-21-09-FIX-PERMISSIONS-ROBUST
    // This trigger ensures that all dashboards (Citizen, Admin, Worker) 
    // have authorized access to the central incident and personnel databases.
    
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // Explicit matches for key collections to handle specific 'list' operations
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    
    match /reports/{reportId} {
      allow read, write: if request.auth != null;
    }
  }
}