rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // GLOBAL OPEN ACCESS POLICY: EMERGENCY UNLOCK FOR DEVELOPMENT
    // This policy ensures 100% data availability for all roles in the Madurai CleanUp network.
    // Deployment ID: MADURAI_GLOBAL_SYNC_V500
    
    match /{allPaths=**} {
      allow read, write: if true;
    }
    
    // Explicit collection overrides for absolute stability during propagation
    match /reports/{reportId} {
      allow read, write: if true;
    }
    
    match /users/{userId} {
      allow read, write: if true;
    }
  }
}