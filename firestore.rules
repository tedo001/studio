rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // FINAL PRODUCTION TRIGGER: 2024-05-21-23-FIX-PERMISSIONS-EXPLICIT
    // This trigger ensures that all dashboards (Citizen, Admin, Worker) 
    // have authorized access to the central incident and personnel databases.
    
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // Explicit matches for the 'reports' collection to ensure 'list' and 'get' operations work across all modules
    match /reports {
      allow read, write: if request.auth != null;
      match /{reportId} {
        allow read, write: if request.auth != null;
      }
      match /{allSubPaths=**} {
        allow read, write: if request.auth != null;
      }
    }
    
    // Explicit matches for the 'users' collection for staff enrollment and profile syncing
    match /users {
      allow read, write: if request.auth != null;
      match /{userId} {
        allow read, write: if request.auth != null;
      }
      match /{allSubPaths=**} {
        allow read, write: if request.auth != null;
      }
    }
  }
}